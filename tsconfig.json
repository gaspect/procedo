{
    "compilerOptions": {
        /* Lenguaje y Ambiente */
        "target": "ES2023",
        "lib": [
            "ES2023"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "rootDir": "./src",
        /* Emisión */
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "removeComments": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        /* Chequeo de Tipos */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true,
        /* Interoperabilidad */
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.spec.ts",
        "**/*.test.ts"
    ]
}