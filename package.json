{
  "name": "procedo",
  "version": "2.0.1",
  "description": "Encapsulate foreing functions in a fancy way",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "tsc",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.16.0",
    "pg": "^8.19.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "tsx": "^4.21.0"
  }
}